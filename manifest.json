{
  "manifest_version": 3,
  "name": "Web Interaction Recorder",
  "version": "1.0",
  "permissions": ["storage", "activeTab", "scripting", "sidePanel"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "popup.html"
  },

  "action": {
    "default_title": "Open Recorder"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
